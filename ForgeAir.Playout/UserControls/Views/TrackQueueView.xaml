<UserControl
    x:Class="ForgeAir.Playout.UserControls.Views.TrackQueueView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:ForgeAir.Playout.UserControls.Views"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources />
    <Grid>
        <ListView
            x:Name="Queue"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            AllowDrop="True"
            DragOver="Queue_DragOver"
            Drop="Queue_Drop"
            ItemsSource="{Binding frontendQueue}"
            MouseMove="Queue_MouseMove"
            PreviewMouseLeftButtonDown="Queue_PreviewMouseLeftButtonDown">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,3">
                                <GradientStop Offset="0" Color="{Binding Background}" />
                                <GradientStop Offset="1" Color="#403E3E" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="{Binding Foreground}" />

                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform X="-50" />
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="{Binding Background}" />
                                        <GradientStop Offset="1" Color="#403E3E" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>

                        </Trigger>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>

                                    <DoubleAnimation
                                        Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                        From="-10"
                                        To="0"
                                        Duration="0:0:0.1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>

                <GridView>
                    <GridViewColumn Width="60" Header="">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <mah:Tile
                                    Width="30"
                                    Height="30"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.SkipToCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}">
                                    <iconPacks:PackIconRemixIcon Height="30" Kind="SkipForwardFill" />
                                </mah:Tile>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="35" Header="Type">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <iconPacks:PackIconRemixIcon Kind="{Binding Icon}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn
                        Width="200"
                        DisplayMemberBinding="{Binding DisplayTitle}"
                        Header="Title" />
                    <GridViewColumn
                        Width="200"
                        DisplayMemberBinding="{Binding DisplayArtists}"
                        Header="Artists" />
                    <GridViewColumn
                        Width="80"
                        DisplayMemberBinding="{Binding DisplayDuration}"
                        Header="Duration" />
                    <GridViewColumn
                        Width="200"
                        DisplayMemberBinding="{Binding DisplayCategories}"
                        Header="Categories" />
                    <GridViewColumn
                        Width="100"
                        DisplayMemberBinding="{Binding WillPlayString}"
                        Header="Will Play" />
                    <GridViewColumn Width="50" Header="">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>

                                <mah:Tile
                                    Width="30"
                                    Height="30"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="Red"
                                    Command="{Binding DataContext.RemoveFromQueueCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}">
                                    <iconPacks:PackIconRemixIcon Height="30" Kind="DeleteBin6Fill" />
                                </mah:Tile>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

    </Grid>
</UserControl>
