<UserControl
    x:Class="ForgeAir.Playout.UserControls.Views.TrackSelectorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:UserControls="clr-namespace:ForgeAir.UI.Core.UserControls;assembly=ForgeAir.UI.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:ForgeAir.Playout.UserControls.Views"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    MinHeight="200"
    MouseDoubleClick="UserControl_MouseDoubleClick"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="79*" />
        </Grid.RowDefinitions>
        <TextBox
            x:Name="SearchBox"
            Grid.Row="0"
            Margin="10,28,186,28"
            mah:TextBoxHelper.ClearTextButton="True"
            mah:TextBoxHelper.IsMonitoring="True"
            mah:TextBoxHelper.IsWaitingForData="True"
            mah:TextBoxHelper.Watermark="Search"
            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        <ListView
            x:Name="Tracks"
            Grid.Row="1"
            ItemsSource="{Binding FilteredTracks}"
            MouseMove="ListView_MouseMove"
            PreviewMouseLeftButtonDown="ListView_PreviewMouseLeftButtonDown"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.IsDeferredScrollingEnabled="True"
            ScrollViewer.ScrollChanged="ScrollViewer_ScrollChanged"
            VirtualizingStackPanel.IsVirtualizing="True"
            VirtualizingStackPanel.VirtualizationMode="Standard">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <EventSetter Event="MouseDoubleClick" Handler="TrackItem_DoubleClick" />
                    <Setter Property="Background" Value="{Binding Background}" />
                    <Setter Property="Foreground" Value="{Binding Foreground}" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="35" Header="Type">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <iconPacks:PackIconRemixIcon Kind="{Binding Icon}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn
                        Width="200"
                        DisplayMemberBinding="{Binding Title}"
                        Header="Title" />
                    <GridViewColumn
                        Width="200"
                        DisplayMemberBinding="{Binding DisplayArtists}"
                        Header="Artists" />
                    <GridViewColumn
                        Width="200"
                        DisplayMemberBinding="{Binding Album}"
                        Header="Album" />
                    <GridViewColumn
                        Width="100"
                        DisplayMemberBinding="{Binding DisplayDuration}"
                        Header="Duration" />
                    <GridViewColumn
                        Width="200"
                        DisplayMemberBinding="{Binding DisplayCategories}"
                        Header="Categories" />

                </GridView>
            </ListView.View>
        </ListView>

        <ComboBox
            x:Name="TrackTypeList"
            Grid.Row="0"
            Margin="10,28,10,28"
            HorizontalAlignment="Right"
            ItemsSource="{Binding TrackTypes}"
            SelectedItem="{Binding SelectedTrackType}" />

    </Grid>
</UserControl>
