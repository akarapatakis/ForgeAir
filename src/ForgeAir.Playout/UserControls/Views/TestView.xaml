<Window
    x:Class="ForgeAir.Playout.UserControls.Views.TestView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ForgeAir.Playout.UserControls"
    Title="TestView"
    Width="800"
    Height="300">

    <Grid>
        <controls:WaveformCanvasControl
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="Black"
            Waveform="{Binding Waveform}" />
    </Grid>

</Window>
