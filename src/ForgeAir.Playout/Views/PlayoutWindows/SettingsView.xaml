<UserControl
    x:Class="ForgeAir.Playout.Views.PlayoutWindows.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:ForgeAir.Playout.Views.PlayoutWindows"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">


    <Grid>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">


            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" MinWidth="266" />
                <ColumnDefinition Width="auto" MinWidth="266" />
                <ColumnDefinition Width="auto" MinWidth="266" />
                <ColumnDefinition Width="auto" MinWidth="266" />
                <ColumnDefinition Width="auto" MinWidth="192" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <mah:Tile
                x:Name="AddTrack"
                Title="Import Tracks"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="green">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="FileAddFill" />
            </mah:Tile>
            <mah:Tile
                x:Name="AddCategory"
                Title="Add Category"
                Grid.Column="1"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="DarkOliveGreen">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="OrganizationChart" />
            </mah:Tile>
            <mah:Tile
                x:Name="AddFx"
                Title="Add FX"
                Grid.Column="2"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="SeaGreen">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="MagicFill" />
            </mah:Tile>
            <mah:Tile
                x:Name="AddNetworkStream"
                Title="Add Network Stream"
                Grid.Column="3"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="ForestGreen">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="BaseStationFill" />
            </mah:Tile>
            <mah:Tile
                Title="Dynamic Jingles"
                Grid.Column="4"
                Width="190"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="DarkSeaGreen">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="StarFill" />
            </mah:Tile>
            <mah:Tile
                Title="Various Options"
                Grid.Row="1"
                Grid.Column="4"
                Width="192"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#0093a6">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="Box1Fill" />
            </mah:Tile>
            <mah:Tile
                x:Name="AudioConfig"
                Title="Audio Configuration"
                Grid.Row="1"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#0093a6">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="Speaker2Fill" />
            </mah:Tile>
            <mah:Tile
                Title="Streaming Encoders"
                Grid.Row="1"
                Grid.Column="1"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#0093a6">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="ServerFill" />
            </mah:Tile>
            <mah:Tile
                Title="Metadata Broadcast"
                Grid.Row="1"
                Grid.Column="2"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#0093a6">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="NewspaperFill" />
            </mah:Tile>
            <mah:Tile
                Title="Plugin Manager"
                Grid.Row="1"
                Grid.Column="3"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#0093a6">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="Puzzle2Fill" />
            </mah:Tile>
            <mah:Tile
                x:Name="EditStation"
                Title="Edit Station Metadata"
                Grid.Row="2"
                Grid.Column="0"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="Orange">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="PencilFill" />
            </mah:Tile>
            <mah:Tile
                Title="ForgeCrowd"
                Grid.Row="2"
                Grid.Column="1"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="DarkOrange">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="TeamFill" />
            </mah:Tile>
            <mah:Tile
                Title="Scheduler"
                Grid.Row="2"
                Grid.Column="2"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="OrangeRed">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="Calendar2Fill" />
            </mah:Tile>
            <mah:Tile
                Title="Track Selector"
                Grid.Row="2"
                Grid.Column="3"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="Orange">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="OrderPlayFill" />
            </mah:Tile>
            <mah:Tile
                Title="Database Misc"
                Grid.Row="2"
                Grid.Column="4"
                Width="190"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="Orange">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="Database2Fill" />
            </mah:Tile>
            <mah:Tile
                Title="Track Manager"
                Grid.Row="3"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="Red">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="FileMusicFill" />
            </mah:Tile>
            <mah:Tile
                Title="Artists Manager"
                Grid.Row="3"
                Grid.Column="1"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="IndianRed">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="User2Fill" />
            </mah:Tile>
            <mah:Tile
                Title="Categories Manager"
                Grid.Row="3"
                Grid.Column="2"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="IndianRed">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="User2Fill" />
            </mah:Tile>
            <mah:Tile
                Title="Categories Manager"
                Grid.Row="3"
                Grid.Column="2"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="DarkRed">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="Archive2Fill" />
            </mah:Tile>
            <mah:Tile
                Title="FX Manager"
                Grid.Row="3"
                Grid.Column="3"
                Width="260"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="MediumVioletRed">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="MagicLine" />
            </mah:Tile>
            <mah:Tile
                x:Name="AboutTile"
                Title="About ForgeAir"
                Grid.Row="3"
                Grid.Column="4"
                Width="190"
                Height="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="Black">
                <iconPacks:RemixIcon
                    Width="80"
                    Height="80"
                    Kind="Information2Fill" />
            </mah:Tile>
        </Grid>
    </Grid>
</UserControl>
