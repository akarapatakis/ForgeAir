<Window
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                 xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
      xmlns:local="clr-namespace:ForgeAir.Playout"
      xmlns:cal="http://www.caliburnproject.org" x:Class="ForgeAir.Playout.SplashScreen"
      mc:Ignorable="d" 
      Height="300" Width="600"
      WindowStartupLocation="CenterScreen"
ResizeMode="NoResize" Topmost="False"
 WindowStyle="None"
      Cursor="Wait"
      Title="ForgeAir Radio Automation Software">
    <Window.Background>
        <ImageBrush ImageSource="/Assets/Splash/splashscreen_new.png"/>
    </Window.Background>

    <Grid>
        <StackPanel>
            <TextBlock Text="by Karapatakis Angelos" FontSize="11" Margin="10,10,10,10" TextAlignment="Right" FontWeight="SemiBold" Foreground="White" FontFamily="Segoe UI Light"/>

        </StackPanel>

        <mah:MetroProgressBar IsIndeterminate="True"  Height="10" VerticalAlignment="Bottom" />

    </Grid>

</Window>
